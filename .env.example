# Birthday Freebies - Environment Variables Template
# Copy this file to .env and fill in with your own values

# ============================================
# Backend Configuration
# ============================================

# FastAPI Application
DEBUG=False
SECRET_KEY=your-super-secret-key-change-in-production

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/birthday_freebies
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=birthday_freebies

# JWT Authentication
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
JWT_REFRESH_EXPIRATION_DAYS=7

# ============================================
# Frontend Configuration
# ============================================

# API Endpoints
REACT_APP_API_URL=http://localhost:8000
REACT_APP_API_TIMEOUT=30000

# ============================================
# Docker & Deployment
# ============================================

# Environment
ENV=development
# Values: development, staging, production

# Port Configuration
BACKEND_PORT=8000
FRONTEND_PORT=5173
